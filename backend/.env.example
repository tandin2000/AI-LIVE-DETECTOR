# OpenAI API key is entered in the app UI and stored in browser localStorage.
# Optional server-side fallback (not required):
# OPENAI_API_KEY=

# Models
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_TRANSCRIPTION_MODEL=gpt-realtime-whisper
OPENAI_CLAIM_MODEL=gpt-4o-mini
OPENAI_FACTCHECK_MODEL=gpt-5.5

# Server (127.0.0.1 in dev — not exposed to LAN)
PORT=3001
HOST=127.0.0.1
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Security — use long random strings in production
JWT_SECRET=change-this-to-a-long-random-string-in-production
SESSION_TOKEN_TTL_SECONDS=900
HISTORY_AUTH_SECRET=change-this-history-auth-secret

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# WebSocket security
WS_AUTH_TIMEOUT_MS=10000
WS_AUDIO_RATE_MAX=25
WS_AUDIO_RATE_WINDOW_MS=1000
